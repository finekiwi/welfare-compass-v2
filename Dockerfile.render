FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

WORKDIR /app

# 시스템 의존성 (psycopg2, curl for healthcheck)
RUN apt-get update && \
    apt-get install -y --no-install-recommends libpq-dev curl && \
    rm -rf /var/lib/apt/lists/*

# backend 의존성
COPY backend/requirements.txt /app/backend/requirements.txt
RUN pip install --no-cache-dir -r /app/backend/requirements.txt

# llm 의존성 (Cohere API 사용 — torch/FlagEmbedding 제외)
RUN pip install --no-cache-dir \
    gunicorn \
    whitenoise \
    dj-database-url \
    "chromadb>=1.4.0" \
    "cohere>=5.20.1" \
    "langchain>=1.2.0" \
    "langchain-chroma>=1.1.0" \
    "langchain-community>=0.4.1" \
    "langchain-openai>=1.1.6" \
    "langgraph>=0.2.0" \
    "langchain-mcp-adapters>=0.1.0" \
    "mcp>=1.6.0" \
    "rank-bm25>=0.2.2"

# 소스 복사
COPY backend/ /app/backend/
COPY llm/ /app/llm/

# === 빌드 타임: ETL + 벡터 인덱싱 (deploy 시 1회만 실행) ===
ARG YOUTH_API_KEY
ARG OPENAI_API_KEY
ARG DJANGO_SECRET_KEY=build-time-placeholder

RUN cd /app/backend && \
    DJANGO_DEBUG=True \
    YOUTH_API_KEY=${YOUTH_API_KEY} \
    python manage.py run_etl --fetch-only && \
    OPENAI_API_KEY=${OPENAI_API_KEY} \
    python -m llm.embeddings.vector_store --reindex

# 정적 파일 수집
RUN cd /app/backend && python manage.py collectstatic --noinput 2>/dev/null || true

EXPOSE ${PORT:-8000}

# === 런타임: migrate + gunicorn만 (cold start 최소화) ===
CMD cd /app/backend && \
    echo "=== Running migrations ===" && \
    python manage.py migrate --noinput && \
    echo "=== Starting gunicorn ===" && \
    gunicorn config.wsgi:application \
    --bind 0.0.0.0:${PORT:-8000} \
    --workers 1 \
    --timeout 120
